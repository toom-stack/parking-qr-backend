generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  role         Role      @default(GUARD)
  createdAt    DateTime  @default(now())
  disabledAt   DateTime?
  email        String?   @unique
  employeeCode String?   @unique
  fullName     String?
  phone        String?
  reports      Report[]  @relation("GuardReports")
}

model Owner {
  id        String    @id @default(cuid())
  fullName  String
  room      String?
  year      Int?
  faculty   String?
  major     String?
  phone     String?
  createdAt DateTime  @default(now())
  vehicles  Vehicle[]
}

model Vehicle {
  id        String   @id @default(cuid())
  ownerId   String
  plateNo   String
  color     String?
  brand     String?
  model     String?
  qrToken   String   @unique
  createdAt DateTime @default(now())
  reports   Report[]
  owner     Owner    @relation(fields: [ownerId], references: [id])
}

model Report {
  id           String        @id @default(cuid())
  vehicleId    String
  guardUserId  String
  problemType  ProblemType
  locationText String?
  note         String?
  reportedAt   DateTime      @default(now())
  createdAt    DateTime      @default(now())
  guard        User          @relation("GuardReports", fields: [guardUserId], references: [id])
  vehicle      Vehicle       @relation(fields: [vehicleId], references: [id])
  images       ReportImage[]
}

model ReportImage {
  id        String   @id @default(cuid())
  reportId  String
  url       String
  createdAt DateTime @default(now())
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

enum Role {
  ADMIN
  GUARD
}

enum ProblemType {
  PARK_RED_WHITE
  BLOCKING
  NO_PARKING
  OTHER
}
